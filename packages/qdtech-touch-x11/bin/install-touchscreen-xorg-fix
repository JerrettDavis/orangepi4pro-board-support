#!/usr/bin/env bash
set -euo pipefail

if [ "$(id -u)" -ne 0 ]; then
  echo "Run as root: sudo $0" >&2
  exit 1
fi

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

install -d -m 0755 /etc/X11/xorg.conf.d /etc/udev/rules.d /usr/local/bin /home/orangepi/.config/autostart
install -m 0755 "$repo_dir/bin/orangepi-touch-map" /usr/local/bin/orangepi-touch-map
install -m 0755 "$repo_dir/bin/orangepi-touch-calibrate" /usr/local/bin/orangepi-touch-calibrate
install -m 0755 "$repo_dir/bin/orangepi-touch-wizard" /usr/local/bin/orangepi-touch-wizard
install -m 0755 "$repo_dir/bin/orangepi-touch-raw-guide" /usr/local/bin/orangepi-touch-raw-guide
install -m 0755 "$repo_dir/bin/qdtech-usb-dump" /usr/local/bin/qdtech-usb-dump 2>/dev/null || true
install -m 0755 "$repo_dir/bin/qdtech-touch-x11" /usr/local/bin/qdtech-touch-x11 2>/dev/null || true
install -m 0644 "$repo_dir/etc/qdtech-touch-x11.conf" /etc/qdtech-touch-x11.conf
install -m 0644 "$repo_dir/etc/udev/rules.d/99-qdtech-mpi7003-touch.rules" /etc/udev/rules.d/99-qdtech-mpi7003-touch.rules
install -m 0644 "$repo_dir/etc/X11/xorg.conf.d/99-qdtech-mpi7003-touchscreen.conf" /etc/X11/xorg.conf.d/99-qdtech-mpi7003-touchscreen.conf
install -m 0644 "$repo_dir/autostart/orangepi-touch-map.desktop" /home/orangepi/.config/autostart/orangepi-touch-map.desktop
install -m 0644 "$repo_dir/autostart/qdtech-touch-x11.desktop" /home/orangepi/.config/autostart/qdtech-touch-x11.desktop
chown orangepi:orangepi /home/orangepi/.config/autostart/orangepi-touch-map.desktop
chown orangepi:orangepi /home/orangepi/.config/autostart/qdtech-touch-x11.desktop

if [ -e /etc/X11/xorg.conf.d/99-odtech-touchscreen.conf ]; then
  mv /etc/X11/xorg.conf.d/99-odtech-touchscreen.conf /etc/X11/xorg.conf.d/99-odtech-touchscreen.conf.disabled
fi

echo "Installed QDtech MPI7003 touchscreen Xorg fix."
echo "Run 'sudo orangepi-touch-calibrate' from the desktop session to refine calibration."
echo "Restart lightdm or reboot after changing persistent calibration."
