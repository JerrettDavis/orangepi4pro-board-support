+++ b/drivers/video/drm/sunxi_drm_drv.c
@@ -34,6 +34,9 @@
 #include "sunxi_drm_bridge.h"
 #include "sunxi_drm_drv.h"
 #include "sunxi_drm_crtc.h"
+#include "sunxi_device/hardware/lowlevel_hdmi20/dw_dev.h"
+#include "sunxi_device/hardware/lowlevel_hdmi20/dw_mc.h"
+#include "sunxi_device/hardware/lowlevel_hdmi20/dw_phy.h"
 
 DECLARE_GLOBAL_DATA_PTR;
 
@@ -968,6 +971,61 @@ static int display_disable(struct display_state *state)
 	return 0;
 }
 
+static bool display_is_stale_hdmi(struct display_state *state,
+				  u8 *phy_stat0, u8 *mc_lockon)
+{
+	u8 phy = 0;
+	u8 lock = 0;
+
+	if (phy_stat0)
+		*phy_stat0 = 0;
+	if (mc_lockon)
+		*mc_lockon = 0;
+
+	if (!state || !state->is_init || !state->is_enable)
+		return false;
+
+	if (!state->conn_state.connector ||
+	    state->conn_state.connector->type != DRM_MODE_CONNECTOR_HDMIA)
+		return false;
+
+	phy = (u8)dw_read(PHY_STAT0);
+	lock = (u8)dw_read(MC_LOCKONCLOCK);
+
+	if (phy_stat0)
+		*phy_stat0 = phy;
+	if (mc_lockon)
+		*mc_lockon = lock;
+
+	if ((phy & PHY_STAT0_TX_PHY_LOCK_MASK) &&
+	    (lock & MC_LOCKONCLOCK_TCLK_MASK) &&
+	    (lock & MC_LOCKONCLOCK_PCLK_MASK))
+		return false;
+
+	return true;
+}
+
+static void display_recover_stale_hdmi_before_logo(struct display_state *state)
+{
+	u8 phy_stat0 = 0;
+	u8 mc_lockon = 0;
+	int disable_ret;
+	int init_ret;
+	char recover[64];
+
+	if (!display_is_stale_hdmi(state, &phy_stat0, &mc_lockon))
+		return;
+
+	printf("sunxi-drm: stale HDMI before logo phy%02x lock%02x; reinit\n",
+	       phy_stat0, mc_lockon);
+	disable_ret = display_disable(state);
+	init_ret = display_init(state);
+
+	snprintf(recover, sizeof(recover), "stale-reinit-d%d-i%d-p%02x-l%02x",
+		 disable_ret, init_ret, phy_stat0, mc_lockon);
+	env_set("opi_logo_recover", recover);
+
+	if (init_ret)
+		DRM_ERROR("stale HDMI logo recovery init failed %d\n", init_ret);
+}
+
 static int display_get_timing_from_dts(struct sunxi_drm_panel *panel,
