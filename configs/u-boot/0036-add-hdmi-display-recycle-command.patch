+static int sunxi_drm_hdmi_recycle(void)
+{
+	struct sunxi_drm_device *drm = sunxi_drm_device_get();
+	struct display_state *state = NULL;
+	struct display_state *candidate = NULL;
+	struct crtc_state *crtc_state;
+	const struct sunxi_drm_crtc *crtc;
+	const struct sunxi_drm_crtc_funcs *crtc_funcs;
+	int was_init = 0;
+	int was_enable = 0;
+	int disable_ret = -ENODEV;
+	int init_ret = -ENODEV;
+	int check_ret = -ENODEV;
+	int enable_ret = -ENODEV;
+	int plane_ret = -ENODEV;
+	char diag[128];
+
+	if (!drm || list_empty(&drm->display_list)) {
+		env_set("opi_recycle_diag", "recycle=drm-missing");
+		return -ENODEV;
+	}
+
+	sunxi_drm_for_each_display(state, drm) {
+		if (!candidate)
+			candidate = state;
+		if (state->conn_state.connector &&
+		    state->conn_state.connector->type == DRM_MODE_CONNECTOR_HDMIA) {
+			candidate = state;
+			break;
+		}
+	}
+
+	state = candidate;
+	if (!state) {
+		env_set("opi_recycle_diag", "recycle=state-missing");
+		return -ENODEV;
+	}
+
+	was_init = state->is_init ? 1 : 0;
+	was_enable = state->is_enable ? 1 : 0;
+
+	disable_ret = display_disable(state);
+	init_ret = display_init(state);
+	if (!init_ret)
+		check_ret = display_check(state);
+	if (!init_ret && !check_ret) {
+		state->backlight = true;
+		enable_ret = display_enable(state);
+	}
+	if (!enable_ret) {
+		plane_ret = display_set_plane(state);
+		crtc_state = &state->crtc_state;
+		crtc = crtc_state->crtc;
+		crtc_funcs = crtc ? crtc->funcs : NULL;
+		if (crtc_funcs && crtc_funcs->flush)
+			crtc_funcs->flush(state);
+		sunxi_drm_connector_backlight(state, true);
+	}
+
+	snprintf(diag, sizeof(diag),
+		 "recycle=w%d%d,d%d,i%d,c%d,e%d,p%d,en%d",
+		 was_init, was_enable, disable_ret, init_ret, check_ret,
+		 enable_ret, plane_ret, state->is_enable ? 1 : 0);
+	env_set("opi_recycle_diag", diag);
+
+	return (disable_ret || init_ret || check_ret || enable_ret || plane_ret) ? -1 : 0;
+}
+
 static int do_sunxi_sunxi_drm(struct cmd_tbl_s *cmdtp, int flag, int argc,
 				char *const argv[])
 {
@@ -1658,6 +1721,8 @@ static int do_sunxi_sunxi_drm(struct cmd_tbl_s *cmdtp, int flag, int argc,
 
