diff --git a/drivers/video/drm/sunxi_drm_hdmi.c b/drivers/video/drm/sunxi_drm_hdmi.c
--- a/drivers/video/drm/sunxi_drm_hdmi.c
+++ b/drivers/video/drm/sunxi_drm_hdmi.c
@@ -426,6 +426,8 @@ static int _sunxi_drv_hdmi_enable(struct sunxi_drm_hdmi *hdmi)
 	struct dw_hdmi_dev_s *dw = NULL;
 	u8 phy_stat0 = 0;
 	u8 mc_lockon = 0;
+	u8 mc_phyrstz = 0;
+	int ret = 0;
+	char diag[96];
 	if (IS_ERR_OR_NULL(hdmi)) {
 		shdmi_err(hdmi);
 		return -1;
@@ -460,7 +462,19 @@ static int _sunxi_drv_hdmi_enable(struct sunxi_drm_hdmi *hdmi)
 	_sunxi_drv_hdmi_set_rate(hdmi);
 
 	/* hdmi driver video ops enable */
-	sunxi_hdmi_config();
+	ret = sunxi_hdmi_config();
+
+	dw = &hdmi->hdmi_core.dw_hdmi;
+	if (dw && dw->sw_init) {
+		phy_stat0 = (u8)dw_read(PHY_STAT0);
+		mc_lockon = (u8)dw_read(MC_LOCKONCLOCK);
+		mc_phyrstz = (u8)dw_read(MC_PHYRSTZ);
+	}
+	snprintf(diag, sizeof(diag),
+		 "drv=ret%d,phy%02x,lock%02x,rst%02x,out%d,clk%d",
+		 ret, phy_stat0, mc_lockon, mc_phyrstz,
+		 hdmi->hdmi_ctrl.drv_enable ? 1 : 0,
+		 hdmi->hdmi_ctrl.drv_clock ? 1 : 0);
+	env_set("opi_hdmi_drv_diag", diag);
 
 	hdmi->hdmi_ctrl.drv_enable = 0x1;
 	hdmi_inf("hdmi drv enable output done\n");
@@ -822,9 +836,12 @@ int _sunxi_drm_hdmi_enable(struct sunxi_drm_connector *conn,
 	struct dw_hdmi_dev_s *dw = NULL;
 	u8 phy_stat0 = 0;
 	u8 mc_lockon = 0;
+	u8 first_phy_stat0 = 0;
+	u8 first_mc_lockon = 0;
 	bool link_locked = false;
+	char secondpass_diag[96];
 
 	_sunxi_drv_hdmi_clock_on(hdmi);
 
@@ -858,6 +875,11 @@ int _sunxi_drm_hdmi_enable(struct sunxi_drm_connector *conn,
 			(mc_lockon & MC_LOCKONCLOCK_TCLK_MASK) &&
 			(mc_lockon & MC_LOCKONCLOCK_PCLK_MASK);
 	}
+	first_phy_stat0 = phy_stat0;
+	first_mc_lockon = mc_lockon;
+	snprintf(secondpass_diag, sizeof(secondpass_diag),
+		 "hdmisp=skip,firstphy%02x,firstlock%02x", first_phy_stat0, first_mc_lockon);
+	env_set("opi_hdmi_secondpass", secondpass_diag);
 
 	if (!link_locked) {
 		hdmi_wrn("hdmi first enable unlocked phy%02x lock%02x; second pass\n",
@@ -894,6 +916,10 @@ int _sunxi_drm_hdmi_enable(struct sunxi_drm_connector *conn,
 		}
 		hdmi_wrn("hdmi second pass result phy%02x lock%02x\n",
 			 phy_stat0, mc_lockon);
+		snprintf(secondpass_diag, sizeof(secondpass_diag),
+			 "hdmisp=run,firstphy%02x,firstlock%02x,secondphy%02x,secondlock%02x",
+			 first_phy_stat0, first_mc_lockon, phy_stat0, mc_lockon);
+		env_set("opi_hdmi_secondpass", secondpass_diag);
 	}
 
 	hdmi->hdmi_ctrl.drm_enable = 0x1;
