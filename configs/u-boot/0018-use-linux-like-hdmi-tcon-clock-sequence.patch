diff --git a/drivers/video/drm/sunxi_device/sunxi_tcon.c b/drivers/video/drm/sunxi_device/sunxi_tcon.c
index 6fc310b..af1a2d0 100644
--- a/drivers/video/drm/sunxi_device/sunxi_tcon.c
+++ b/drivers/video/drm/sunxi_device/sunxi_tcon.c
@@ -464,13 +464,24 @@ static int _sunxi_tcon_hdmi_clk_prepare(struct sunxi_tcon *hwtcon,
 
 	if (hwtcon->tcon_top)
 		sunxi_tcon_top_clk_enable(hwtcon->tcon_top);
 
+	/*
+	 * Linux's sun60iw2 HDMI path fully drops the TCON pixel/bus clocks,
+	 * pulses the bus reset, sets the requested pixel clock, then enables
+	 * bus and pixel clocks. The U-Boot BSP used to set the pixel clock on
+	 * top of the previous state, which can leave HDMI silent until Linux
+	 * performs its later mode-change reset.
+	 */
+	if (!IS_ERR_OR_NULL(hwtcon->mclk))
+		clk_disable(hwtcon->mclk);
+
+	if (!IS_ERR_OR_NULL(hwtcon->mclk_bus))
+		clk_disable(hwtcon->mclk_bus);
+
 	if (!IS_ERR_OR_NULL(hwtcon->rst_bus_tcon))
+		clk_disable(hwtcon->rst_bus_tcon);
+
+	if (!IS_ERR_OR_NULL(hwtcon->rst_bus_tcon))
 		clk_prepare_enable(hwtcon->rst_bus_tcon);
 
-	/* set rate */
 	clk_set_rate(hwtcon->mclk, pclk);
 	rate_diff = (clk_round_rate(hwtcon->mclk, pclk) - pclk);
 	if (rate_diff != 0)
 		DRM_WARN("suxni tcon hdmi set rate: %ldHz and get diff: %ldHz\n",
 			pclk, rate_diff);
