+static int sunxi_drm_fbcycle(void)
+{
+	struct sunxi_drm_device *drm = sunxi_drm_device_get();
+	struct display_state *state = NULL;
+	struct display_state *candidate = NULL;
+	struct drm_framebuffer *fb;
+	struct crtc_state *crtc_state;
+	const struct sunxi_drm_crtc *crtc;
+	const struct sunxi_drm_crtc_funcs *crtc_funcs;
+	u32 *pixels;
+	u32 colors[] = {
+		0xffffffff,
+		0xff000000,
+		0xffffffff,
+		0xff000000,
+		0xffffffff,
+		0xff000000,
+		0xffffffff,
+		0xff000000,
+	};
+	u32 x, y, stripe, color;
+	int was_enabled = 0;
+	int disable_ret = 0;
+	int init_ret = 0;
+	int check_ret = 0;
+	int enable_ret = 0;
+	int plane_ret = 0;
+	int flush_ret = 0;
+	char diag[224];
+
+	if (!drm || list_empty(&drm->display_list)) {
+		env_set("opi_fbcycle_diag", "fbcycle=drm-missing");
+		return -ENODEV;
+	}
+
+	sunxi_drm_for_each_display(state, drm) {
+		if (!candidate)
+			candidate = state;
+		if (state->conn_state.type == DRM_MODE_CONNECTOR_HDMIA) {
+			candidate = state;
+			break;
+		}
+		if (state->is_enable)
+			candidate = state;
+	}
+
+	state = candidate;
+	if (!state) {
+		env_set("opi_fbcycle_diag", "fbcycle=state-missing");
+		return -ENODEV;
+	}
+
+	was_enabled = state->is_enable ? 1 : 0;
+	if (state->is_enable) {
+		disable_ret = display_disable(state);
+		mdelay(120);
+	}
+
+	init_ret = display_init(state);
+	if (init_ret)
+		goto out_diag;
+
+	check_ret = display_check(state);
+	if (check_ret)
+		goto out_diag;
+
+	state->backlight = true;
+	enable_ret = display_enable(state);
+	if (enable_ret)
+		goto out_diag;
+
+	fb = drm_framebuffer_lookup(drm, state->fb_id);
+	if (!fb || !fb->dma_addr || !fb->width || !fb->height) {
+		init_ret = -ENODEV;
+		goto out_diag;
+	}
+
+	pixels = (u32 *)fb->dma_addr;
+	stripe = fb->width / ARRAY_SIZE(colors);
+	if (!stripe)
+		stripe = 1;
+
+	for (y = 0; y < fb->height; y++) {
+		for (x = 0; x < fb->width; x++) {
+			color = colors[(x / stripe) % ARRAY_SIZE(colors)];
+			if (x < 12 || y < 12 || x >= fb->width - 12 || y >= fb->height - 12)
+				color = 0xffffffff;
+			if (x > fb->width / 2 - 6 && x < fb->width / 2 + 6)
+				color = 0xffffffff;
+			if (y > fb->height / 2 - 6 && y < fb->height / 2 + 6)
+				color = 0xffffffff;
+			pixels[y * fb->width + x] = color;
+		}
+	}
+
+	flush_dcache_range((ulong)fb->dma_addr,
+			   ALIGN((ulong)(fb->dma_addr + fb->buf_size),
+				 CONFIG_SYS_CACHELINE_SIZE));
+
+	plane_ret = display_set_plane(state);
+	crtc_state = &state->crtc_state;
+	crtc = crtc_state->crtc;
+	crtc_funcs = crtc ? crtc->funcs : NULL;
+	if (crtc_funcs && crtc_funcs->flush)
+		crtc_funcs->flush(state);
+	else
+		flush_ret = -ENOSYS;
+	sunxi_drm_connector_backlight(state, true);
+
+out_diag:
+	snprintf(diag, sizeof(diag),
+		 "fbcycle=was%d,dis%d,init%d,chk%d,en%d,plane%d,flush%d,isen%d",
+		 was_enabled, disable_ret, init_ret, check_ret, enable_ret,
+		 plane_ret, flush_ret, state->is_enable ? 1 : 0);
+	env_set("opi_fbcycle_diag", diag);
+
+	if (disable_ret)
+		return disable_ret;
+	if (init_ret)
+		return init_ret;
+	if (check_ret)
+		return check_ret;
+	if (enable_ret)
+		return enable_ret;
+	return plane_ret;
+}
+
 static int do_sunxi_sunxi_drm(struct cmd_tbl_s *cmdtp, int flag, int argc,
 				char *const argv[])
 {
@@ -1711,6 +1818,8 @@ static int do_sunxi_sunxi_drm(struct cmd_tbl_s *cmdtp, int flag, int argc,
 
