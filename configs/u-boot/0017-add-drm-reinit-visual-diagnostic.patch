 	return plane_ret ? plane_ret : 0;
 }
 
+static int sunxi_drm_reinit_active(void)
+{
+	struct sunxi_drm_device *drm = sunxi_drm_device_get();
+	struct display_state *state = NULL;
+	struct display_state *candidate = NULL;
+	int was_init = 0;
+	int was_enable = 0;
+	int disable_ret = 0;
+	int init_ret = -ENODEV;
+	int enable_ret = -ENODEV;
+	char diag[160];
+
+	if (!drm || list_empty(&drm->display_list)) {
+		env_set("opi_drm_reinit_diag", "drmreinit=drm-missing");
+		return -ENODEV;
+	}
+
+	sunxi_drm_for_each_display(state, drm) {
+		if (!candidate)
+			candidate = state;
+		if (state->conn_state.type == DRM_MODE_CONNECTOR_HDMIA) {
+			candidate = state;
+			break;
+		}
+	}
+
+	state = candidate;
+	if (!state) {
+		env_set("opi_drm_reinit_diag", "drmreinit=state-missing");
+		return -ENODEV;
+	}
+
+	was_init = state->is_init ? 1 : 0;
+	was_enable = state->is_enable ? 1 : 0;
+
+	disable_ret = display_disable(state);
+	init_ret = display_init(state);
+	if (!init_ret) {
+		state->backlight = true;
+		enable_ret = display_enable(state);
+	}
+
+	snprintf(diag, sizeof(diag),
+		 "drmreinit=type%d,was%d%d,dis%d,init%d,en%d,now%d%d,mode%ux%u,clk%u,force%d",
+		 state->conn_state.type, was_init, was_enable,
+		 disable_ret, init_ret, enable_ret,
+		 state->is_init ? 1 : 0, state->is_enable ? 1 : 0,
+		 state->conn_state.mode.hdisplay, state->conn_state.mode.vdisplay,
+		 state->conn_state.mode.clock, state->force_output ? 1 : 0);
+	env_set("opi_drm_reinit_diag", diag);
+
+	return disable_ret ? disable_ret : (init_ret ? init_ret : enable_ret);
+}
+
 static int do_sunxi_sunxi_drm(struct cmd_tbl_s *cmdtp, int flag, int argc,
 				char *const argv[])
 {
@@ -1812,6 +1864,8 @@ static int do_sunxi_sunxi_drm(struct cmd_tbl_s *cmdtp, int flag, int argc,
 
 	} else if (!strcmp(argv[1], "fbtest")) {
 		ret = sunxi_drm_fbtest();
+	} else if (!strcmp(argv[1], "reinit")) {
+		ret = sunxi_drm_reinit_active();
 	}
 
 
